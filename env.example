# ═══════════════════════════════════════════════════════════
#  FitWay Hub – Environment Variables
#  Copy this file to .env for local dev.
#  On Railway set these in: Project → Service → Variables
# ═══════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── AI ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ─────────────────────────────────────────────────
#
# RAILWAY (recommended):
#   Link the MySQL service to this service in the Railway dashboard.
#   Railway will auto-inject MYSQL_URL — no extra config needed.
#
#   OR manually paste the Public URL from Railway MySQL → Connect tab:
#   DATABASE_URL=mysql://root:<password>@<host>:<port>/<database>
#
#   When DATABASE_URL or MYSQL_URL is set the app skips CREATE DATABASE
#   (Railway manages the DB) and connects directly.
#   Leave DB_AUTO_CREATE=false on Railway.
#
# LOCAL DEV (no DATABASE_URL / MYSQL_URL):
#   The app falls back to DB_* vars below and auto-creates the DB.
#
DATABASE_URL=
MYSQL_URL=

# Used only when DATABASE_URL and MYSQL_URL are empty (local dev):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_mysql_password
DB_NAME=mongolian

# Set true ONLY for local dev when you need the app to CREATE the database.
# Leave false (or unset) on Railway — the DB already exists there.
DB_AUTO_CREATE=false

# SSL — leave false unless your provider requires it.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── App URL ───────────────────────────────────────────────────
# Set to the PUBLIC URL of this backend (the address that browsers and the
# mobile app use to reach it). Used for OAuth callbacks, email links, and
# (when R2 is not configured) for prefixing uploaded image URLs so they
# resolve from any device.
#
# IMPORTANT: do NOT leave it at http://localhost in production. Anything
# pinned to localhost is unreachable from other devices. The code now
# refuses to use a localhost APP_BASE_URL for image URLs precisely to
# avoid the "image visible to admin, missing for everyone else" bug.
#
# Examples:
#   Local dev (same machine only):  http://localhost:3000
#   Local dev (test from phone):    http://192.168.x.x:3000  (your LAN IP)
#   Railway:                        https://fitwayhub.up.railway.app
#   Production:                     https://www.fitwayhub.com
APP_BASE_URL=https://www.fitwayhub.com

# ── Frontend (Vite) ───────────────────────────────────────────
# Full address of the backend used by client-side fetches.
# On Railway, set this to your Railway public domain.
VITE_API_BASE=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# ── Apple In-App Purchase ─────────────────────────────────────
APPLE_IAP_SHARED_SECRET=your_apple_shared_secret
APPLE_IAP_SANDBOX=true

# ── Google Play In-App Purchase ───────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.fitwayhub.app
GOOGLE_PLAY_SERVICE_ACCOUNT=./google-play-service-account.json

# ── Uploads directory (no-R2 path) ────────────────────────────
# Where the local-disk upload fallback writes admin-uploaded files (and
# where the /uploads/* route serves them from). Must be an ABSOLUTE path.
# Leave empty to use <project>/uploads (NOT recommended in production —
# `git pull` / redeploys can wipe the project directory).
#
# For Hostinger / shared hosts: put this on a path OUTSIDE your deployed
# app folder so deploys never touch it. Example:
#   UPLOADS_DIR=/home/u901594571/uploads
#
# Make sure the Node process has read+write permission on this directory:
#   mkdir -p /home/u901594571/uploads && chmod 755 /home/u901594571/uploads
UPLOADS_DIR=

# ── Cloudflare R2 Storage ─────────────────────────────────────
# RECOMMENDED for production. When all five R2_* variables are set, uploaded
# images / videos are stored in Cloudflare R2 (S3-compatible object storage)
# and the public R2 URL is saved to the database. This is the right setup if:
#   - You deploy to ephemeral disks (Railway, Heroku, Fly, etc.) — local disk
#     is wiped on every redeploy, so locally-stored uploads disappear.
#   - You run multiple instances behind a load balancer — each instance has
#     its own disk and won't see files uploaded to the other.
#   - You want images to be served from a CDN.
#
# When these are NOT set, uploads fall back to local disk under <project>/uploads
# and the URL is built from APP_BASE_URL above. Make sure APP_BASE_URL is the
# public URL of this backend or images won't load on mobile / other devices.
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=fitwayhub
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
