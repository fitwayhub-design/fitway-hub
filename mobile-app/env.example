# ═══════════════════════════════════════════════════════════
#  FitWayHub Mobile – Environment Variables
#  Copy to .env for local dev. The mobile build is a Vite SPA
#  packaged via Capacitor — it has no server of its own and
#  only needs the URL of the backend it should talk to.
# ═══════════════════════════════════════════════════════════

# Where the backend API lives. The dev server proxies /api and
# /uploads to this URL. In a Capacitor build the same URL is
# used directly via fetch.
VITE_API_BASE=https://your-backend.example.com

# Firebase Web Push (FCM) public key. Only needed if you want
# in-app push notifications via Firebase.
VITE_FIREBASE_VAPID_KEY=

# Native (Android/iOS) OS push notifications.
#   - Leave unset/"false" to disable native push (in-app + web push still work).
#   - Set to "true" to enable. Requires the Firebase client config files to be
#     present in the build (see README → "Native push notifications setup"):
#         Android: mobile-app/android/app/google-services.json
#         iOS:     mobile-app/ios/App/App/GoogleService-Info.plist
#   In CI this is set automatically to "true" when the ANDROID_GOOGLE_SERVICES_JSON
#   repository secret is present.
VITE_ENABLE_NATIVE_PUSH=false

# Extra hostnames the dev server should accept. Comma-separated.
# Most setups leave this empty.
VITE_ALLOWED_HOSTS=

# Optional Gemini key for in-app AI features.
GEMINI_API_KEY=
