node_modules
dist
.env
.env.local
.env.*.local

# ── Secrets & signing material — NEVER commit these ──────────────────────────
# (a server .env with DB credentials was previously committed here by mistake;
#  these patterns make sure no credential or signing key is tracked again.)
*.env
firebase-service-account.json
google-services.json
ios/App/App/GoogleService-Info.plist
*.keystore
*.jks
*.p12
*.mobileprovision
*.cer
*.certSigningRequest
android/key.properties

# Capacitor native projects are committed so external CI scripts that
# expect android/ and ios/ to exist (e.g. zip-upload builders) work
# without first running 'npx cap add'. Build artefacts inside them are
# still ignored below.

# Android Gradle artefacts
android/.gradle/
android/.idea/
android/app/build/
android/build/
android/local.properties
android/capacitor-cordova-android-plugins/.gradle/
android/capacitor-cordova-android-plugins/build/

# iOS / Xcode artefacts
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/

# Misc
*.log
.DS_Store
